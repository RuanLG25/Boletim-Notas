@{
    ViewData["Title"] = "Boletim";
    List<string> disciplinas = ViewBag.Disciplinas;
    List<double> notas = ViewBag.Notas;
    double media = notas.Average();
}

<h2>Boletim de Notas</h2>

<!-- Passo 3: Tabela com Disciplina, Nota e Status -->
<table border="1" cellpadding="8">
    <thead>
        <tr>
            <th>Disciplina</th>
            <th>Nota</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @for (int i = 0; i < disciplinas.Count; i++)
        {
            <tr>
                <td>@disciplinas[i]</td>
                <td>@notas[i]</td>

                <!-- Passo 4: @if Aprovado / Reprovado -->
                <td>
                    @if (notas[i] >= 5)
                    {
                        <span style="color:green; font-weight:bold;">Aprovado</span>
                    }
                    else
                    {
                        <span style="color:red; font-weight:bold;">Reprovado</span>
                    }
                </td>
            </tr>
        }
    </tbody>

    <!-- Passo 5: Média geral no final -->
    <tfoot>
        <tr>
            <td><strong>Média Geral</strong></td>
            <td><strong>@media.ToString("F2")</strong></td>
            <td>
                @if (media >= 5)
                {
                    <span style="color:green; font-weight:bold;">Aprovado</span>
                }
                else
                {
                    <span style="color:red; font-weight:bold;">Reprovado</span>
                }
            </td>
        </tr>
    </tfoot>
</table>

<!-- Passo 6: @switch para classificação -->
<br />
@{
    string conceito = "";

    switch (true)
    {
        case bool _ when media >= 9:
            conceito = "A";
            break;
        case bool _ when media >= 7:
            conceito = "B";
            break;
        case bool _ when media >= 5:
            conceito = "C";
            break;
        default:
            conceito = "D";
            break;
    }
}

<h3>Conceito Final: <strong>@conceito</strong></h3>